---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} — Finny Sh</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap');

      * { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --bg: #0a0a0b;
        --bg-card: #111113;
        --border: #1e1e22;
        --text: #e4e4e7;
        --text-dim: #71717a;
        --accent: #22d3ee;
        --mono: 'JetBrains Mono', monospace;
        --sans: 'Inter', system-ui, sans-serif;
      }

      html { background: var(--bg); color: var(--text); font-family: var(--sans); }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem;
        padding-top: 8rem;
      }

      nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2rem;
        border-bottom: 1px solid var(--border);
        background: rgba(10, 10, 11, 0.85);
        backdrop-filter: blur(12px);
      }

      nav .logo { font-family: var(--mono); font-size: 0.9rem; font-weight: 700; color: var(--text); text-decoration: none; }
      nav .logo .accent { color: var(--accent); }
      nav .nav-links { display: flex; gap: 1.5rem; }
      nav .nav-links a { font-family: var(--mono); font-size: 0.8rem; color: var(--text-dim); text-decoration: none; }
      nav .nav-links a:hover { color: var(--accent); }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
        z-index: 0;
      }

      main {
        position: relative;
        z-index: 1;
        max-width: 640px;
        width: 100%;
      }

      .nav {
        font-family: var(--mono);
        font-size: 0.8rem;
        margin-bottom: 3rem;
      }

      .nav a { color: var(--text-dim); text-decoration: none; }
      .nav a:hover { color: var(--accent); }

      .meta {
        font-family: var(--mono);
        font-size: 0.75rem;
        color: var(--text-dim);
        margin-bottom: 1rem;
      }

      h1 {
        font-family: var(--sans);
        font-size: 1.75rem;
        font-weight: 600;
        line-height: 1.3;
        margin-bottom: 3rem;
        color: var(--text);
      }

      .prose {
        line-height: 1.8;
        font-size: 1rem;
        color: var(--text);
      }

      .prose p { margin-bottom: 1.5rem; }
      .prose p:last-child { margin-bottom: 0; }

      .prose h1, .prose h2, .prose h3 {
        font-family: var(--mono);
        font-weight: 600;
        color: var(--text);
        margin: 2rem 0 1rem;
        line-height: 1.3;
      }

      .prose h1 { font-size: 1.4rem; }
      .prose h2 { font-size: 1.15rem; }
      .prose h3 { font-size: 1rem; color: var(--text-dim); }

      .prose hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.5rem 0;
      }

      .prose strong { color: var(--accent); font-weight: 500; }

      .prose code {
        font-family: var(--mono);
        font-size: 0.875em;
        background: rgba(34, 211, 238, 0.08);
        border: 1px solid rgba(34, 211, 238, 0.15);
        padding: 0.1em 0.4em;
        border-radius: 4px;
        color: var(--accent);
      }

      footer {
        position: relative;
        z-index: 1;
        margin-top: 4rem;
        font-family: var(--mono);
        font-size: 0.7rem;
        color: var(--text-dim);
        text-align: center;
      }

      footer a { color: var(--text-dim); text-decoration: none; }
      footer a:hover { color: var(--accent); }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="logo">finny<span class="accent">.sh</span></a>
      <div class="nav-links"><a href="/journal">journal</a></div>
    </nav>
    <main>
      <div class="meta">{post.data.date.toISOString().slice(0, 10)}</div>
      <h1>{post.data.title}</h1>
      <div class="prose">
        <Content />
      </div>
    </main>

    <footer>
      <p>finny.sh · <a href="/">home</a></p>
    </footer>
  </body>
</html>
